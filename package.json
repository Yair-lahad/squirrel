{
  "name": "squirrel",
  "version": "0.1.0",
  "description": "Personal money flow dashboard",
  "main": "backend/server.js",
  "scripts": {
    "dev:backend": "node backend/server.js",
    "dev:frontend": "npm --prefix frontend run dev",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "build": "npm --prefix frontend run build",
    "start": "npm run build && node backend/server.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "israeli-bank-scrapers": "^6.8.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
